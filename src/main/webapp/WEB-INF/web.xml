<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.inventory.servlet.user.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddStockServlet</servlet-name>
        <servlet-class>com.inventory.servlet.inventory.AddStockServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddStockServlet</servlet-name>
        <url-pattern>/addStock</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddSaleServlet</servlet-name>
        <servlet-class>com.inventory.servlet.sales.AddSaleServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddSaleServlet</servlet-name>
        <url-pattern>/processSale</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>views/user/login.jsp</welcome-file>
    </welcome-file-list>
</web-app>