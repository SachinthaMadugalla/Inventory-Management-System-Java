<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <!-- ================================================================
         Servlet Declarations
         Using @WebServlet annotations on each class, so explicit
         <servlet> entries here are optional — kept for clarity.
         ================================================================ -->

    <!-- Login / Logout / Register -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.inventory.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.inventory.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.inventory.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- Dashboard -->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.inventory.servlet.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <!-- Inventory — Component 01 -->
    <servlet>
        <servlet-name>AddStockServlet</servlet-name>
        <servlet-class>com.inventory.servlet.AddStockServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddStockServlet</servlet-name>
        <url-pattern>/addStock</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViewInventoryServlet</servlet-name>
        <servlet-class>com.inventory.servlet.ViewInventoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewInventoryServlet</servlet-name>
        <url-pattern>/viewInventory</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditStockServlet</servlet-name>
        <servlet-class>com.inventory.servlet.EditStockServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditStockServlet</servlet-name>
        <url-pattern>/editStock</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteStockServlet</servlet-name>
        <servlet-class>com.inventory.servlet.DeleteStockServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteStockServlet</servlet-name>
        <url-pattern>/deleteStock</url-pattern>
    </servlet-mapping>

    <!-- Expiry Management — Component 02 -->
    <servlet>
        <servlet-name>ExpiryServlet</servlet-name>
        <servlet-class>com.inventory.servlet.ExpiryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ExpiryServlet</servlet-name>
        <url-pattern>/expiryManagement</url-pattern>
    </servlet-mapping>

    <!-- Sales -->
    <servlet>
        <servlet-name>SalesServlet</servlet-name>
        <servlet-class>com.inventory.servlet.SalesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SalesServlet</servlet-name>
        <url-pattern>/processSale</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViewSalesServlet</servlet-name>
        <servlet-class>com.inventory.servlet.ViewSalesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewSalesServlet</servlet-name>
        <url-pattern>/viewSales</url-pattern>
    </servlet-mapping>

    <!-- Reports -->
    <servlet>
        <servlet-name>ReportServlet</servlet-name>
        <servlet-class>com.inventory.servlet.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReportServlet</servlet-name>
        <url-pattern>/reports</url-pattern>
    </servlet-mapping>

    <!-- Default welcome page redirects to login -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>
